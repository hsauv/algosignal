# Automatic HTTPS (Let's Encrypt) reverse proxy in front of the Next.js app.
# DOMAIN and ACME_EMAIL are injected via environment variables.
{
	email {$ACME_EMAIL}
	# rate_limit is a third-party module; it must be ordered explicitly.
	order rate_limit before reverse_proxy
}

{$DOMAIN} {
	encode gzip

	# Throttle write endpoints (report + comment creation) per client IP to
	# block flooding. Browsing/reading is not affected. IPs are used in-memory
	# by the module only — nothing is persisted (data minimisation preserved).
	@writes {
		method POST
		path /api/reports /api/reports/*/comments
	}
	rate_limit @writes {
		zone writes {
			key {remote_host}
			events 5
			window 1m
		}
	}

	reverse_proxy web:3000
	# Data minimisation (RGPD): access logging is intentionally NOT enabled,
	# so visitor IP addresses are not persisted. Do not add a `log` directive
	# here without a defined retention policy.
}
