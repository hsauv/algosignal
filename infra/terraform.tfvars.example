# Copy to terraform.tfvars and fill in. NEVER commit terraform.tfvars (secrets).

# --- Outscale ---------------------------------------------------------------
outscale_access_key = "AKIA_xxx"
outscale_secret_key = "xxxxxxxx"
region              = "cloudgouv-eu-west-1" # SecNumCloud region

# OMI id of a Debian 12 image in that region (region-specific — look it up).
image_id = "ami-xxxxxxxx"

# --- Access -----------------------------------------------------------------
# Contents of your SSH public key (not the path).
ssh_public_key = "ssh-ed25519 AAAA... you@host"
# Your current public IP, /32, so only you can SSH.
admin_ssh_cidr = "203.0.113.4/32"

# --- DNS (Gandi) ------------------------------------------------------------
gandi_pat    = "your-gandi-personal-access-token"
gandi_domain = "exemple.fr"
subdomain    = "@" # "@" for exemple.fr, or "app" for app.exemple.fr

# --- Backups ----------------------------------------------------------------
backup_bucket_name = "algosignal-backups"
