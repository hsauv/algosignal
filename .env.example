# ---------------------------------------------------------------------------
# AlgoSignal — environment variables
# Copy this file to `.env` and fill in the values.
# ---------------------------------------------------------------------------

# PostgreSQL connection string (Railway provides this).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/algosignal?schema=public"

# ---------------------------------------------------------------------------
# Moderation access (single-moderator model)
# ---------------------------------------------------------------------------

# Shared password that unlocks the /admin dashboard. Citizens never need an
# account — this only protects the moderation area. Choose a strong value.
ADMIN_PASSWORD="replace-me-with-a-strong-password"

# Optional: secret used to sign anti-spam form tokens. If unset, falls back to
# ADMIN_PASSWORD. Set it to decouple the two.
# FORM_SECRET="another-long-random-string"
